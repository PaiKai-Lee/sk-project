meta {
  name: Refresh Token
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/refresh-token
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{refresh-token}}"
  }
}

vars:post-response {
  access-token: res.body.data.accessToken
  refresh-token: res.body.data.refreshToken
}

settings {
  encodeUrl: true
  timeout: 0
}
