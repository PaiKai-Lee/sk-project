meta {
  name: Create Transaction
  type: http
  seq: 3
}

post {
  url: http://localhost:3000/api/transactions
  body: json
  auth: inherit
}

body:json {
  {
    "remarks": "{{?remark}}",
    "items": [
      {
        "uid": "ts01",
        "value": 10,
        "details": "this is details"
      },
      {
        "uid": "ts02",
        "value": -10,
        "details": "is details"
      }
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
